{
  "name": "arete-widget",
  "version": "0.1.3",
  "description": "Arete Widget \u2014 create virtual widgets from YAML definitions and let them live on a CNS/CP realm. Each widget declares CP capabilities and renders a faceplate window in lieu of the physical device.",
  "author": "Anto <anto@padi.io>",
  "license": "(MIT OR Apache-2.0)",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "node scripts/patch-sdk.js",
    "patch": "node scripts/patch-sdk.js",
    "start": "electron .",
    "test:connect": "node scripts/test-connect.js",
    "test:widget": "node scripts/test-widget.js",
    "test:spec": "node scripts/test-spec.js",
    "dist": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "test:ui": "node scripts/test-ui.js",
    "test:faceplate": "node scripts/test-faceplate.js",
    "test:startup": "node scripts/diag-startup.js",
    "test:ping": "node scripts/test-ping.js",
    "test:library": "node scripts/test-library.js",
    "test:propagate": "node scripts/test-propagate.js",
    "test:compose": "node scripts/test-compose.js",
    "test:compose-ui": "node scripts/test-compose-ui.js",
    "test:lease": "node scripts/test-lease.js"
  },
  "dependencies": {
    "arete-sdk": "^0.1.6",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5",
    "jsdom": "^25.0.1"
  },
  "build": {
    "appId": "io.padi.arete.widget",
    "productName": "Arete Widget",
    "directories": {
      "output": "release"
    },
    "files": [
      "core/**/*",
      "electron/**/*",
      "renderer/**/*",
      "widgets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "target": "dmg",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Arete Widget ${version}",
      "artifactName": "Arete-Widget-${version}-${arch}.dmg",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 190,
          "type": "file"
        },
        {
          "x": 390,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Arete-Widget-Setup-${version}.exe"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "artifactName": "Arete-Widget-${version}-${arch}.AppImage"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "project-arete",
        "repo": "arete-widget",
        "releaseType": "release"
      }
    ]
  }
}
