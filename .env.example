# Optional defaults for Arete Widget.
# Copy to `.env` (never commit `.env`). These pre-fill the Config form on first
# run; after the first successful connect, saved settings take precedence.

ARETE_PROTOCOL=wss:
# ARETE_HOST=my.realm.example.com
ARETE_PORT=443
# ARETE_USER=
# ARETE_PASS=

# If your control plane uses a self-signed cert chain, "1" allows insecure TLS
# for that connection only. Leave OFF for any host with a valid public
# certificate (e.g. dashboard.test.cns.dev).
ARETE_ALLOW_SELF_SIGNED=0

# The System name this app registers in the realm on connect. Widget nodes are
# created under this System.
# ARETE_SYSTEM_NAME=Arete Widget
